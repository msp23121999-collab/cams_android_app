# ─────────────────────────────────────────────────────────────────────────────
# Android app configuration
#
#   cp .env.example .env      then set the URL for your setup
#
# Injected at build time by the Secrets Gradle Plugin and read in code as
# BuildConfig.API_BASE_URL -> AppConfig.BASE_URL -> Retrofit.
#
# NEVER commit the real .env — it is excluded by .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Where the backend is running. Keep the trailing slash.
#
#   Android emulator      http://10.0.2.2:8000/api/v1/
#     (10.0.2.2 is a special alias meaning "the computer running the emulator")
#
#   Physical device       http://<your-computer-LAN-IP>:8000/api/v1/
#     e.g. http://192.168.1.50:8000/api/v1/  — phone must be on the same Wi-Fi
#
#   Production            https://api.your-college.edu/api/v1/
#
API_BASE_URL=http://10.0.2.2:8000/api/v1/
