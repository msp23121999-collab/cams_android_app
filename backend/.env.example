# ─────────────────────────────────────────────────────────────────────────────
# CAMS backend configuration
#
#   cp .env.example .env      then fill in the values below
#
# NEVER commit the real .env — it is excluded by .gitignore.
# Every value here is a PLACEHOLDER.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
# "development" or "production".
# Setting this to production also: disables API docs, disables all debug
# endpoints, forces Secure cookies, and enforces the CORS allow-list.
ENVIRONMENT=development

# ── Database (required) ──────────────────────────────────────────────────────
# Use PostgreSQL. SQLite silently accepts enum/foreign-key/type violations that
# PostgreSQL rejects, which lets schema bugs reach production undetected.
DATABASE_URL=postgresql+asyncpg://REPLACE_USER:REPLACE_PASSWORD@localhost:5432/cams

# Alternative to DATABASE_URL — set these and the URL is assembled for you.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL_MODE=

# ── Authentication (required) ────────────────────────────────────────────────
# The server refuses to start without this. Generate a unique value per
# environment — never reuse one across dev and production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Send auth cookies only over HTTPS. Forced to true when ENVIRONMENT=production.
COOKIE_SECURE=false

# ── Payments — Razorpay (optional) ───────────────────────────────────────────
# Until set, payment creation returns 503. A fee is only ever marked paid after
# the signature is verified server-side; the client callback is never trusted.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email (optional) ─────────────────────────────────────────────────────────
# Used for password-reset and email-change flows. Until set, those emails
# simply do not send; nothing else is affected.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Base URL used to build links inside those emails.
FRONTEND_BASE_URL=http://localhost:3000

# ── AI chatbot (optional) ────────────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
CHATBOT_MODEL=llama-3.1-70b-versatile
CHATBOT_MAX_TOKENS=1000

# ── Push notifications — Firebase (optional) ─────────────────────────────────
# Supply the service-account JSON either inline or by path. With neither set, push
# is disabled and logged; in-app notifications continue to work normally.
# These are SECRETS — never commit them.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_FILE=

# ── Cache / rate-limit storage (optional) ────────────────────────────────────
# The app runs fine without Redis; rate limiting falls back to per-worker
# in-memory counters and logs a warning.
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_STORAGE_URI=

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# Only enable when a reverse proxy sets X-Forwarded-For AND strips any
# client-supplied value. If nothing trustworthy sets it, a client can forge the
# header and get a fresh limit bucket per request — i.e. no rate limiting.
RATE_LIMIT_TRUST_FORWARDED_FOR=false

# Per-IP login limit. Deliberately generous: a campus NATs all its users behind
# one address, so a strict per-IP limit locks out legitimate students.
RATE_LIMIT_LOGIN=120/minute

# The real brute-force defence: failed logins per account. Only failures count,
# and a successful login clears the counter.
RATE_LIMIT_LOGIN_PER_ACCOUNT=10/15minutes

RATE_LIMIT_PASSWORD_RESET_REQUEST=5/hour
RATE_LIMIT_PASSWORD_RESET_CONFIRM=10/hour
RATE_LIMIT_CHANGE_PASSWORD=10/hour
RATE_LIMIT_TOKEN_REFRESH=60/minute

# ── CORS ─────────────────────────────────────────────────────────────────────
# Exact origins allowed to call the API. In production this list is
# authoritative — set it to your real domain and nothing else.
CORS_ORIGINS=["http://localhost:3000"]
