# CAMS ERP Enterprise Backend Configuration
ENVIRONMENT=development

# Database Configuration (PostgreSQL/SQLite)
# To use a single URL:
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/cams

# Or configure separate components:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cams
DB_USER=postgres
DB_PASSWORD=root
DB_SSL_MODE=prefer

# Redis URL for celery / cache
REDIS_URL=redis://localhost:6379/0

# Security Configurations
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Integration Keys
GEMINI_API_KEY=
GROQ_API_KEY=
